# AI Travel Guide - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Configuration (optional - only if using OpenAI instead of Ollama)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Server Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
